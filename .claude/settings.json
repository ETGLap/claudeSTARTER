    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "node .claude/notify/notify.js stop" }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          { "type": "command", "command": "node .claude/notify/notify.js notification" }
        ]
      }
    ]
  }
}
